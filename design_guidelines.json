  "universal_guidelines": [
    "Do not use gradients for text.",
    "Ensure all text has a contrast ratio of at least 4.5:1 against the background.",
    "Use 'sonner' for all toast notifications.",
    "Use 'lucide-react' for icons.",
    "All interactive elements must have 'data-testid'.",
    "Mobile-first: Ensure map controls are touch-friendly (min 44px target)."
